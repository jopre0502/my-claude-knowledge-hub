{
  // Allow long lines (tables, URLs, badges)
  "MD013": false,
  // Allow headings without surrounding blank lines (compact instruction docs)
  "MD022": false,
  // Allow duplicate headings in different sections
  "MD024": { "siblings_only": true },
  // Allow lists without surrounding blank lines (compact format)
  "MD032": false,
  // Allow inline HTML (badges, details/summary)
  "MD033": false,
  // Allow bare URLs
  "MD034": false,
  // Allow spaces in code spans (e.g. ```python, ```bash)
  "MD038": false
}
