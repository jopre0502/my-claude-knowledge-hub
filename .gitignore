# ===================================================
# ~/.claude/ Knowledge Hub - Erweiterte Whitelist
# ===================================================
# Strategy: Ignore EVERYTHING, then whitelist all
# self-developed elements (skills, agents, commands, hooks)
# and curated documentation.
# ===================================================

# Ignore everything by default
*

# ===== WHITELIST: Git Config & Tooling =====
!.gitignore
!.gitattributes
!.editorconfig
!.markdownlint.jsonc

# ===== WHITELIST: Global Claude Instructions =====
!CLAUDE.md

# ===== WHITELIST: Community Standard Files =====
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!CHANGELOG.md

# ===== WHITELIST: GitHub Config =====
!.github/
!.github/**

# ===== WHITELIST: Agent Definitions =====
!agents/
!agents/*.md

# ===== WHITELIST: All Skills =====
!skills/
!skills/*/
!skills/**

# ===== WHITELIST: Commands =====
!commands/
!commands/*

# ===== WHITELIST: Hooks =====
!hooks/
!hooks/*

# ===== WHITELIST: Rules =====
!rules/
!rules/*

# ===== WHITELIST: Output Styles =====
!output-styles/
!output-styles/*

# ===== WHITELIST: Analysis & Documentation =====
!docs/
!docs/analysis/
!docs/analysis/*

# ===== WHITELIST: Assets =====
!assets/
!assets/*

# ===== WHITELIST: Local Plugins (self-developed) =====
!plugins/
!plugins/cache/
!plugins/cache/local-plugins/
!plugins/cache/local-plugins/ai-visualisation/
!plugins/cache/local-plugins/ai-visualisation/**

# ===== WHITELIST: Secrets Setup (Example Files Only) =====
!secrets-setup/
!secrets-setup/**

# ===== EXPLICIT DENIES (safety net) =====
# Credentials and secrets
.credentials.json
settings.json
settings.local.json
mcp.json
*.env
!*.env.example
*.secret
*.token

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx
*.cert
id_rsa*
id_ed25519*
id_ecdsa*

# Session data (large, ephemeral)
history.jsonl
session-env/
file-history/
debug/
plans/
/cache/
paste-cache/
shell-snapshots/
backups/
plugins/cache/marketplace/
plugins/installed_plugins.json
projects/
security_warnings_state_*.json

# Permission-Audit Logs (generated at runtime by hook)
skills/permission-audit/artifacts/*.log

# Build artifacts
__pycache__/
*.pyc

# WSL Zone Identifier metadata
*:Zone.Identifier
