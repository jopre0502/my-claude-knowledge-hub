# ===================================================
# ~/.claude/ Knowledge Hub - Erweiterte Whitelist
# ===================================================
# Strategy: Ignore EVERYTHING, then whitelist all
# self-developed elements (skills, agents, commands, hooks)
# and curated documentation.
# ===================================================

# Ignore everything by default
*

# ===== WHITELIST: Git Config =====
!.gitignore

# ===== WHITELIST: Global Claude Instructions =====
!CLAUDE.md

# ===== WHITELIST: Agent Definitions =====
!agents/
!agents/*.md

# ===== WHITELIST: All Skills =====
!skills/
!skills/*/
!skills/**

# ===== WHITELIST: Commands =====
!commands/
!commands/*

# ===== WHITELIST: Hooks =====
!hooks/
!hooks/*

# ===== WHITELIST: Output Styles =====
!output-styles/
!output-styles/*

# ===== WHITELIST: Assets =====
!assets/
!assets/*

# ===== EXPLICIT DENIES (safety net) =====
# Credentials and secrets
.credentials.json
settings.json
settings.local.json
mcp.json

# Session data (large, ephemeral)
history.jsonl
session-env/
file-history/
debug/
plans/
cache/
paste-cache/
shell-snapshots/
backups/
plugins/
projects/
security_warnings_state_*.json

# Build artifacts
__pycache__/
*.pyc

# WSL Zone Identifier metadata
*:Zone.Identifier
